{
  "name": "blog-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "node backend/server.js",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "server": "nodemon ./server.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "redis": "docker start redis || docker run -d -p 6379:6379 --name redis redis",
    "dev:full": "npm run redis && concurrently \"npm run dev\" \"nodemon backend/server.js\"",
    "test:unit": "vitest run --config config/vitest.unit.config.js",
    "test:unit:watch": "vitest --config config/vitest.unit.config.js",
    "test:unit:coverage": "vitest run --config config/vitest.unit.config.js --coverage",
    "test:integration": "vitest run --config config/vitest.integration.config.js",
    "test:integration:watch": "vitest --config config/vitest.integration.config.js",
    "test:concurrency": "vitest run --config config/vitest.concurrency.config.js",
    "test:api": "vitest run --config config/vitest.api.config.js",
    "test:websocket": "vitest run --config config/vitest.websocket.config.js",
    "test:queue": "vitest run --config config/vitest.queue.config.js",
    "test:performance": "vitest run --config config/vitest.performance.config.js",
    "test:security": "vitest run --config config/vitest.security.config.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "@tailwindcss/vite": "^4.1.11",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.1",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.27.1",
    "gsap": "^3.13.0",
    "jsonwebtoken": "^9.0.2",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.536.0",
    "mongodb": "^6.19.0",
    "mongoose": "^8.18.0",
    "postprocessing": "^6.38.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.62.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-loading-skeleton": "^3.5.0",
    "react-router-dom": "^7.7.1",
    "redis": "^5.11.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.182.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.17",
    "vite": "^7.0.4",
    "vitest": "^4.1.2"
  }
}
